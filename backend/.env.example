# Copy this file to .env and fill in your key
# Get a FREE key at https://openrouter.ai/keys (no credit card required)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Free OpenRouter model to use for all agents.
# gpt-oss-120b is currently one of the strongest free models on OpenRouter -
# strong instruction-following (important for the strict JSON reply format
# the agents use) and Apache-licensed. The free model list changes often
# though - if this one gets rate-limited or removed, check
# https://openrouter.ai/models?max_price=0 for current alternatives, or use
# the auto-router below which adapts automatically.
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Alternatives worth trying if the above is unavailable or rate-limited:
#   openai/gpt-oss-20b:free        - smaller/faster, still solid at JSON
#   openrouter/free                - auto-router, always finds *something* free
#   meta-llama/llama-3.3-70b-instruct:free

# STRONGLY RECOMMENDED - and REQUIRED for voice input. Two jobs:
# 1) LLM backup: OpenRouter's free tier shares ONE account-wide daily cap
#    across every free model - once that's hit, ALL OpenRouter models fail
#    at once (you'll see "Rate limit exceeded: free-models-per-day" even
#    after switching models). Groq is a completely separate free
#    account/quota (no card, ~1000+ requests/day) that survives that.
# 2) Speech-to-text: candidate voice answers are transcribed with Groq's
#    free hosted Whisper API - far more accurate and reliable than the
#    browser's built-in speech recognition. Without this key, voice input
#    is disabled entirely (typing still works fine).
# Get a key in ~30 seconds, no card: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Code execution for the coding round: Judge0 CE's free public instance,
# no key required. (Piston's public API was shut down / went
# whitelist-only in Feb 2026, so this replaced it.)
JUDGE0_URL=https://ce.judge0.com

# Voices are handled entirely in the browser (Web Speech API) - no key,
# no network call, nothing to configure here. Nothing else needed for voice.

# CORS - your frontend URL
FRONTEND_ORIGIN=http://localhost:5173
